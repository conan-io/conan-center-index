             #include <unordered_map>
             #include <unordered_set>
 
-            #define COLLADABU_HASH_MAP std::tr1::unordered_map
-			#define COLLADABU_HASH_MULTIMAP std::tr1::unordered_multimap
-            #define COLLADABU_HASH_SET std::tr1::unordered_set
