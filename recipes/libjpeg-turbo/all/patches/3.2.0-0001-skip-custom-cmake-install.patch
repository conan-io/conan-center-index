Use GNUInstallDirs from CMake instead of custom one
Also fix installation when using java support

https://github.com/conan-io/conan-center-index/issues/27762
https://github.com/conan-io/conan-center-index/pull/29891


diff --git a/CMakeLists.txt b/CMakeLists.txt
index a1293db..d83a81f 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -206,7 +206,7 @@ if(CMAKE_INSTALL_PREFIX STREQUAL "${CMAKE_INSTALL_DEFAULT_PREFIX}")
   endif()
 endif()
 
-include(cmakescripts/GNUInstallDirs.cmake)
+include(GNUInstallDirs)
 
 macro(report_directory var)
   if(CMAKE_INSTALL_${var} STREQUAL CMAKE_INSTALL_FULL_${var})
diff --git a/jna/CMakeLists.txt b/jna/CMakeLists.txt
index 0321b7d..eef9afa 100644
--- a/jna/CMakeLists.txt
+++ b/jna/CMakeLists.txt
@@ -37,8 +37,6 @@ endif()
 if(NOT DEFINED CMAKE_INSTALL_DEFAULT_JAVADIR)
   set(CMAKE_INSTALL_DEFAULT_JAVADIR "<CMAKE_INSTALL_DATAROOTDIR>/java")
 endif()
-GNUInstallDirs_set_install_dir(JAVADIR
-  "The directory into which Java classes should be installed")
 GNUInstallDirs_get_absolute_install_dir(CMAKE_INSTALL_FULL_JAVADIR
   CMAKE_INSTALL_JAVADIR)
 set(CMAKE_INSTALL_JAVADIR ${CMAKE_INSTALL_JAVADIR} PARENT_SCOPE)
