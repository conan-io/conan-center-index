Disable Werror to avoid build failure on newer compilers with -Wstringop-truncation, which is treated as an error due to -Werror. The specific error is:
src/user/user_init.c:271:3: error: ‘__builtin_strncpy’ output truncated before terminating nul copying 12 bytes from a string of the same length [-Werror=stringop-truncation]


diff --git a/cmake/MujocoOptions.cmake b/cmake/MujocoOptions.cmake
index a606220..c931ecb 100644
--- a/cmake/MujocoOptions.cmake
+++ b/cmake/MujocoOptions.cmake
@@ -86,7 +86,6 @@ get_mujoco_extra_link_options(EXTRA_LINK_OPTIONS)

 if(CMAKE_CXX_COMPILER_ID STREQUAL "GNU" OR (CMAKE_CXX_COMPILER_ID MATCHES "Clang" AND NOT MSVC))
   set(EXTRA_COMPILE_OPTIONS
-      -Werror
       -Wall
       -Wpedantic
       -Wimplicit-fallthrough
