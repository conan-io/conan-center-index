-if(ENABLE_DATA_ODBC)
-	list(APPEND _ext_deps "ODBC")
-endif()
-if(ENABLE_APACHECONNECTOR)
-	list(APPEND _ext_deps "APR" "Apache")
-endif()
-if(_ext_deps)
-	list(JOIN _ext_deps ", " _ext_deps_str)
-	message(STATUS "Using external ${_ext_deps_str}")
-endif()
