From 9c00f34fe2cb8689ca2947463537d1e0835f0c41 Mon Sep 17 00:00:00 2001
From: Naoto Kondo <cgigcp3yqt@gmail.com>
Date: Sat, 14 Feb 2026 22:12:44 +0900
Subject: [PATCH] Add missing headers

Explicitly include <cstdint> and <limits> in TriangleMeshDistance.h.
These are required for uint64_t and std::numeric_limits, fixing compilation errors on modern compilers like GCC 15.
---
 TriangleMeshDistance/include/tmd/TriangleMeshDistance.h | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/TriangleMeshDistance/include/tmd/TriangleMeshDistance.h b/TriangleMeshDistance/include/tmd/TriangleMeshDistance.h
index a207935..2b1ee7c 100644
--- a/TriangleMeshDistance/include/tmd/TriangleMeshDistance.h
+++ b/TriangleMeshDistance/include/tmd/TriangleMeshDistance.h
@@ -28,6 +28,8 @@
 #include <algorithm>
 #include <unordered_map>
 #include <cmath>
+#include <cstdint>
+#include <limits> 
 
 namespace tmd
 {
-- 
2.53.0

