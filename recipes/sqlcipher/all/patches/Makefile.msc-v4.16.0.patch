# Use sqlcipher.dll and sqlcipher.lib as MSVC DLL and static import library names.
# Drop /NODEFAULTLIB:msvcrt from LDFLAGS so /MD host tools (e.g. lemon) link with UCRT.

--- a/Makefile.msc
+++ b/Makefile.msc
@@ -303,17 +303,17 @@
 SQLITE3H = sqlite3.h
 !ENDIF
 
 # This is the name to use for the SQLite dynamic link library (DLL).
 #
 !IFNDEF SQLITE3DLL
 !IF $(FOR_WIN10)!=0
-SQLITE3DLL = winsqlite3.dll
-!ELSE
-SQLITE3DLL = sqlite3.dll
+SQLITE3DLL = sqlcipher.dll
+!ELSE
+SQLITE3DLL = sqlcipher.lib
 !ENDIF
 !ENDIF
 
 # This is the name to use for the SQLite import library (LIB).
 #
 !IFNDEF SQLITE3LIB
 !IF $(FOR_WIN10)!=0
@@ -725,15 +725,15 @@
 # This is the core library that the shell executable should depend on.
 #
 !IFNDEF SHELL_CORE_DEP
 !IF $(DYNAMIC_SHELL)!=0 || $(FOR_WIN10)!=0
 SHELL_CORE_DEP = $(SQLITE3DLL)
 # <<mark>>
 !ELSEIF $(USE_AMALGAMATION)==0
-SHELL_CORE_DEP = libsqlite3.lib
+SHELL_CORE_DEP = sqlcipher.lib
 # <</mark>>
 !ELSE
 SHELL_CORE_DEP =
 !ENDIF
 !ENDIF
 
 # <<mark>>
@@ -748,15 +748,15 @@
 # This is the core library that the shell executable should link with.
 #
 !IFNDEF SHELL_CORE_LIB
 !IF $(DYNAMIC_SHELL)!=0 || $(FOR_WIN10)!=0
 SHELL_CORE_LIB = $(SQLITE3LIB)
 # <<mark>>
 !ELSEIF $(USE_AMALGAMATION)==0
-SHELL_CORE_LIB = libsqlite3.lib
+SHELL_CORE_LIB = sqlcipher.lib
 # <</mark>>
 !ELSE
 SHELL_CORE_LIB =
 !ENDIF
 !ENDIF
 
 # These are additional linker options used for the shell executable.
@@ -1238,17 +1238,17 @@
 LTLINKOPTS = $(LTLINKOPTS) /NODEFAULTLIB:libucrt.lib /DEFAULTLIB:ucrt.lib
 !ENDIF
 !ENDIF
 
 # If either debugging or symbols are enabled, enable PDBs.
 #
 !IF $(DEBUG)>1 || $(SYMBOLS)!=0
-LDFLAGS = /NODEFAULTLIB:msvcrt /DEBUG $(LDOPTS)
-!ELSE
-LDFLAGS = /NODEFAULTLIB:msvcrt $(LDOPTS)
+LDFLAGS = /DEBUG $(LDOPTS)
+!ELSE
+LDFLAGS = $(LDOPTS)
 !ENDIF
 
 # <<mark>>
 # ^^^^^^^^-- content between mark and /mark omitted from autoconf/Makefile.msc
