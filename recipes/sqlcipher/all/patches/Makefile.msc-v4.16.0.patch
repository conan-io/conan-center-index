 	dumpbin /all tclsqlite.lo \
 		| $(TCLSH_CMD) $(TOP)\tool\replace.tcl include "^\s+/EXPORT:_?((?:Sqlite3|Tclsqlite3)_[^@]*)(?:@\d+)?$$" \1 \
 		| sort >> tclsqlite3.def
 
@@ -1866,17 +1866,17 @@
 
